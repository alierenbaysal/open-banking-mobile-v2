{
  "realm": "open-banking",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": true,
  "registrationEmailAsUsername": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "permanentLockout": false,
  "maxFailureWaitSeconds": 900,
  "failureFactor": 5,
  "defaultSignatureAlgorithm": "PS256",
  "accessTokenLifespan": 3600,
  "accessCodeLifespan": 120,
  "ssoSessionIdleTimeout": 7200,
  "ssoSessionMaxLifespan": 36000,
  "verifyEmail": false,

  "roles": {
    "realm": [
      { "name": "tpp-developer", "description": "TPP developer — can register applications and access sandbox" },
      { "name": "bank-customer", "description": "Bank Dhofar customer — can approve/reject consent requests" },
      { "name": "qantara-admin", "description": "Qantara platform administrator" }
    ]
  },

  "clientScopes": [
    {
      "name": "accounts",
      "description": "Read account information (AISP)",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "true", "consent.screen.text": "View your bank accounts, balances, and transactions" }
    },
    {
      "name": "payments",
      "description": "Initiate payments (PISP)",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "true", "consent.screen.text": "Initiate payments from your bank account" }
    },
    {
      "name": "fundsconfirmations",
      "description": "Confirm fund availability (CBPII)",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "true", "consent.screen.text": "Check if funds are available in your account" }
    }
  ],

  "clients": [
    {
      "clientId": "qantara-admin-cli",
      "name": "Qantara Admin CLI",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "qantara-admin-secret-tnd",
      "protocol": "openid-connect",
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": false,
      "fullScopeAllowed": true,
      "description": "Service account for ob-tpp-manager"
    },
    {
      "clientId": "qantara-portal",
      "name": "Qantara Developer Portal",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "implicitFlowEnabled": false,
      "rootUrl": "https://qantara.tnd.bankdhofar.com",
      "redirectUris": ["https://qantara.tnd.bankdhofar.com/*"],
      "webOrigins": ["https://qantara.tnd.bankdhofar.com"],
      "defaultClientScopes": ["openid", "profile", "email"],
      "attributes": { "pkce.code.challenge.method": "S256", "post.logout.redirect.uris": "https://qantara.tnd.bankdhofar.com/*" }
    },
    {
      "clientId": "bd-online",
      "name": "BD Online — Internet Banking",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "rootUrl": "https://banking.tnd.bankdhofar.com",
      "redirectUris": ["https://banking.tnd.bankdhofar.com/*"],
      "webOrigins": ["https://banking.tnd.bankdhofar.com"],
      "defaultClientScopes": ["openid", "profile", "email"],
      "attributes": { "pkce.code.challenge.method": "S256" }
    },
    {
      "clientId": "masroofi-demo",
      "name": "Masroofi — Personal Finance Manager",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "masroofi-demo-secret-tnd",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "rootUrl": "https://masroofi.tnd.bankdhofar.com",
      "redirectUris": ["https://masroofi.tnd.bankdhofar.com/*"],
      "webOrigins": ["https://masroofi.tnd.bankdhofar.com"],
      "defaultClientScopes": ["openid", "profile", "email"],
      "optionalClientScopes": ["accounts", "payments", "fundsconfirmations"],
      "attributes": { "pkce.code.challenge.method": "S256" }
    }
  ],

