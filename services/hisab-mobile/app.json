{
  "expo": {
    "name": "Hisab",
    "slug": "hisab-mobile",
    "scheme": "hisab",
    "version": "1.0.1",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#00B894"
    },
    "ios": {
      "bundleIdentifier": "com.bankdhofar.hisab",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.bankdhofar.hisab",
      "adaptiveIcon": {
        "backgroundColor": "#00B894"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ]
  }
}