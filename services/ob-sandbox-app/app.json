{
  "expo": {
    "name": "BD Sandbox",
    "slug": "ob-sandbox-app",
    "scheme": "bdsandbox",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#4D9134"
    },
    "ios": {
      "bundleIdentifier": "com.bankdhofar.sandbox",
      "supportsTablet": true
    },
    "android": {
      "package": "com.bankdhofar.sandbox",
      "adaptiveIcon": {
        "backgroundColor": "#4D9134"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
